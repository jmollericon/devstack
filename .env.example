# DevStack Environment Configuration
# Copy this file to .env and modify the values as needed

# Container Names
MYSQL57_CONTAINER_NAME=mysql5.7.44
MYSQL84_CONTAINER_NAME=mysql8.4.9
PHPMYADMIN_CONTAINER_NAME=phpmyadmin
PHPMYADMIN8_CONTAINER_NAME=phpmyadmin8
POSTGRES_CONTAINER_NAME=postgres16
PGADMIN_CONTAINER_NAME=pgadmin
PHP74_CONTAINER_NAME=apache-php7.4
PHP82_CONTAINER_NAME=apache-php8.2
PHP84_CONTAINER_NAME=apache-php8.4

# Network Configuration
NETWORK_NAME=devstack_network

# Service Ports Configuration
MYSQL_57_PORT=3306
MYSQL_84_PORT=3308
PHPMYADMIN_PORT=8080
PHPMYADMIN8_PORT=8088
POSTGRES_PORT=5432
PGADMIN_PORT=5050
PHP_74_PORT=8074
PHP_82_PORT=8082
PHP_84_PORT=8084

# MySQL 5.7 Database Configuration
MYSQL_57_ROOT_PASSWORD=root
MYSQL_57_PASSWORD=root
MYSQL_57_DATABASE=devstack
MYSQL_57_USER=devstack

# MySQL 8.4 Database Configuration
MYSQL_84_ROOT_PASSWORD=root
MYSQL_84_PASSWORD=root
MYSQL_84_DATABASE=devstack
MYSQL_84_USER=devstack

# PostgreSQL Database Configuration
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=devstack
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
